#include <stdio.h>
#include <stdlib.h>  
#include <string.h>
#include <ctype.h>

#define MAX 100

char stack[MAX];
int top = -1;

// Standard stack operations
void push(char c) {
    if (top >= MAX - 1) {
        printf("Stack overflow\n");
        return;
    }
    stack[++top] = c;
}

char pop() {
    if (top < 0) {
        return '\0';
    }
    return stack[top--];
}

char peek() {
    if (top < 0) {
        return '\0';
    }
    return stack[top];
}

// Function to return precedence of operators
int precedence(char op) {
    switch(op) {
        case '+':
        case '-':
            return 1;
        case '*':
        case '/':
            return 2;
        case '^':
            return 3;
        default:
            return 0;
    }
}

// Check if character is an operator
int isOperator(char c) {
    return (c == '+' || c == '-' || c == '*' || c == '/' || c == '^');
}

void infixToPostfix(char* infix, char* postfix) {
    int i = 0, j = 0;
    char c;

    while ((c = infix[i++]) != '\0') {
        // If character is an operand (letter or number), add to output
        if (isalnum(c)) {
            postfix[j++] = c;
        }
        // If '(', push to stack
        else if (c == '(') {
            push(c);
        }
        // If ')', pop until '(' is found
        else if (c == ')') {
            while (top >= 0 && peek() != '(') {
                postfix[j++] = pop();
            }
            pop(); // Remove '(' from stack
        }
        // If character is an operator
        else if (isOperator(c)) {
            if (c == '^') {
                // Right-associative: pop only if stack top has HIGHER precedence
                while (top >= 0 && precedence(peek()) > precedence(c)) {
                    postfix[j++] = pop();
                }
            } else {
                // Left-associative: pop if stack top has GREATER or EQUAL precedence
                while (top >= 0 && precedence(peek()) >= precedence(c)) {
                    postfix[j++] = pop();
                }
            }
            push(c);
        }
    }   

    // Pop all remaining operators from the stack
    while (top >= 0) {
        postfix[j++] = pop();
    }
    postfix[j] = '\0'; // Null-terminate the string
}

int main() {
    char infix[MAX], postfix[MAX];
    
    printf("Enter an infix expression (e.g., a+b*(c^d-e)): ");
    scanf("%s", infix);
    
    infixToPostfix(infix, postfix);
    
    printf("Postfix expression: %s\n", postfix);
    
    return 0;
}
